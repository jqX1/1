# Vision Proxy Configuration
# Copy this file to .env and modify values as needed.
# All variables have sensible defaults — most users don't need to change anything.

# Ollama vision model to use for image descriptions.
# Recommended alternatives: minicpm-v:latest, llama3.2-vision:latest, qwen2.5vl:7b
VP_VISION_MODEL=moondream:latest

# Custom prompt for the vision model. Comment out for auto-detection
# (Chinese prompt for DeepSeek/Qwen/Moonshot, English for others).
# VP_VISION_PROMPT=请详细描述这张图片的内容。列出所有物体、人物、文字、颜色、动作、场景以及任何值得注意的细节。

# Ollama API address (change if Ollama runs on a different machine)
VP_OLLAMA_API=http://localhost:11434

# Upstream text-only LLM API (OpenAI-compatible)
VP_UPSTREAM_API=https://api.deepseek.com

# Optional: separate API for requests that contain images.
# When set, image requests go here, pure-text requests go to VP_UPSTREAM_API.
# VP_UPSTREAM_VISION_API=https://api.openai.com/v1

# Proxy listen port
VP_PORT=8080

# Log level: DEBUG, INFO, WARNING, ERROR
VP_LOG_LEVEL=INFO

# Max image size in MB (rejects larger files before loading into memory)
VP_MAX_IMAGE_MB=50

# Image error handling: skip (continue with warning) | placeholder (static text) | fail (abort request)
VP_ON_IMAGE_ERROR=skip
